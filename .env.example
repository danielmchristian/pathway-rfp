# Connection string used by the FastAPI app and Alembic.
# For host-run dev (default workflow): localhost:5432.
# For backend running inside docker compose: replace `localhost` with `db`.
DATABASE_URL=postgresql+asyncpg://pathway:pathway@localhost:5432/pathway

ANTHROPIC_API_KEY=
# FDC = FoodData Central (food identity, nutrition). Free key at fdc.nal.usda.gov/api-key-signup
USDA_FDC_API_KEY=
# AMS = Agricultural Marketing Service Market News (wholesale prices). Free signup at mymarketnews.ams.usda.gov
USDA_AMS_API_KEY=
GOOGLE_PLACES_API_KEY=
RESEND_API_KEY=
RESEND_FROM_EMAIL=rfp@yourdomain.com
IMAP_HOST=
IMAP_USER=
IMAP_PASSWORD=

LOG_LEVEL=INFO
ENV=dev
