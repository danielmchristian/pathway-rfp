# Connection string used by the FastAPI app and Alembic.
# For host-run dev (default workflow): localhost:5432.
# For backend running inside docker compose: replace `localhost` with `db`.
DATABASE_URL=postgresql+asyncpg://pathway:pathway@localhost:5432/pathway

ANTHROPIC_API_KEY=
# FDC = FoodData Central (food identity, nutrition). Free key at fdc.nal.usda.gov/api-key-signup
USDA_FDC_API_KEY=
# AMS = Agricultural Marketing Service Market News (wholesale prices). Free signup at mymarketnews.ams.usda.gov
USDA_AMS_API_KEY=
GOOGLE_PLACES_API_KEY=
RESEND_API_KEY=
# Phase 5+ send identity. Domain must be Resend-verified. Distributor
# replies route here via Reply-To (mirrors From).
RFP_FROM_EMAIL=procurement@yourdomain.com
# Phase 5 demo recipient override. Outbound RFPs go to
# `<local>+<distributor-slug>@<domain>` so all distributor mail lands
# in one inbox you can poll. Use the local-part of a Gmail / Workspace
# mailbox that accepts plus-addressing.
RFP_DEMO_INBOX=you@yourdomain.com
# Legacy alias — Phase 5+ uses RFP_FROM_EMAIL. Kept for compatibility.
RESEND_FROM_EMAIL=
# Planning estimate the aggregator uses to multiply per-serving
# ingredient quantities into weekly demand. Emails label this as a
# planning estimate so distributors quote tier pricing, not a firm PO.
COVERS_PER_DISH_PER_WEEK=150
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=

LOG_LEVEL=INFO
ENV=dev
